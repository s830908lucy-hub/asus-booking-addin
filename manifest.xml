<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ★ 必填：唯一識別碼，不要更改 -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>JingYuan Wu</ProviderName>
  <DefaultLocale>zh-TW</DefaultLocale>
  <DisplayName DefaultValue="ASUS 會議室預約"/>
  <Description DefaultValue="在新增 Outlook 會議時，一鍵開啟 ASUS Booking System 並自動搜尋立德8F會議室"/>

  <IconUrl DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/icon128.png"/>
  <HighResolutionIconUrl DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/icon128.png"/>
  <SupportUrl DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/"/>

  <AppDomains>
    <AppDomain>https://booking.asus.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <!-- 舊版 Outlook 支援 -->
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/taskpane.html"/>
        <RequestedHeight>350</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- 現代版 Outlook 支援（VersionOverrides） -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets>
        <bt:Set Name="Mailbox" MinVersion="1.3"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16"  resid="Icon.16x16"/>
                    <bt:Image size="32"  resid="Icon.32x32"/>
                    <bt:Image size="80"  resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/icon16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/icon32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/icon128.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url"  DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/commands.html"/>
        <bt:Url id="Taskpane.Url"  DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/asus-booking-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"            DefaultValue="會議室預約"/>
        <bt:String id="TaskpaneButton.Label"  DefaultValue="🏢 預約會議室"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="開啟 ASUS Booking System，自動搜尋立德8F會議室"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
